{
  "compilerOptions": {
    "module": "CommonJS",
    "declaration": true,
    "declarationMap": true,        // <-- adicione (ajuda no debug)
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2020",
    "resolveJsonModule": true,
    "sourceMap": true,
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node"
  },
  "include": ["src/**/*"],           // <-- adicione
  "exclude": ["node_modules", "dist"] // <-- adicione
}