{
  "name": "@mikemajesty/mongo-migration",
  "version": "0.0.8",
  "description": "MongoDB migrations.",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:all": "npm run build && npm run build:cjs",
    "dev": "tsc --watch",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build:all",
    "clean": "rm -rf dist",
    "test": "jest"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "keywords": [
    "mongodb",
    "migration",
    "database",
    "cli",
    "nestjs"
  ],
  "author": "Mike Lima",
  "license": "MIT",
  "dependencies": {
    "@nestjs/common": "^11.1.27",
    "colorette": "^2.0.20",
    "fs": "^0.0.1-security",
    "inquirer": "^14.0.2",
    "nest-commander": "^3.20.1",
    "path": "^0.12.7"
  },
  "peerDependencies": {
    "mongodb": ">=7.0.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.13.2",
    "jest": "^30.2.0",
    "mongodb": "^7.4.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mikemajesty/mongo-migration.git"
  },
  "bugs": {
    "url": "https://github.com/mikemajesty/mongo-migration/issues"
  },
  "homepage": "https://github.com/mikemajesty/mongo-migration#readme"
}
